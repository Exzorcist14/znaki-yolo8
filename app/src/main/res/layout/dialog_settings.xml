<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/tts_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_tts"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tts_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/settings_tts_hint"
            android:textColor="#7F000000"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tts_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            tools:text="Голос: русский" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/tts_test_button"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/settings_tts_test"
                android:textAllCaps="false"
                android:textSize="13sp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/tts_install_button"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/settings_tts_open_system"
                android:textAllCaps="false"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="14dp"
            android:background="#1F000000" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_threshold"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"
            android:text="@string/settings_threshold_hint"
            android:textColor="#7F000000"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <SeekBar
                android:id="@+id/conf_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/conf_value"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="50%" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
